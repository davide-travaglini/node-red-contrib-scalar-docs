  {
    "id": "scalar-example-tab",
    "type": "tab",
    "label": "Scalar Docs Example",
    "disabled": false,
    "info": "Example flow for node-red-contrib-scalar-docs.\nOpen http://localhost:1880/api-docs after deploying."
