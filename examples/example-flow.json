  {
    "id": "scalar-fn-get-users",
    "type": "function",
    "z": "scalar-example-tab",
    "name": "List Users",
    "func": "const users = [\n    { id: 1, name: 'Alice Smith',  email: 'alice@example.com' },\n    { id: 2, name: 'Bob Jones',   email: 'bob@example.com'   },\n    { id: 3, name: 'Carol White', email: 'carol@example.com' }\n];\nconst limit = parseInt(msg.req.query.limit) || users.length;\nmsg.payload    = users.slice(0, limit);\nmsg.statusCode = 200;\nreturn msg;",
    "outputs": 1,
    "noerr": 0,
    "initialize": "",
    "finalize": "",
    "libs": [],
    "x": 350,
    "y": 120,
    "wires": [["scalar-resp-get-users"]]
